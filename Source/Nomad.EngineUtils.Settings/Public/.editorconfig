# top-most EditorConfig file
root = true

# -----------------------------------------------------------------------------
# General settings for all files
# -----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# -----------------------------------------------------------------------------
# C# specific settings
# -----------------------------------------------------------------------------
[*.cs]

# =============================================================================
# Indentation & Tabs (spaces only)
# =============================================================================
indent_style = space
indent_size = 4

# =============================================================================
# Brace style (Allman – opening brace on new line)
# =============================================================================
csharp_new_line_before_open_brace = all
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Prefer braces always
csharp_prefer_braces = true:warning

# =============================================================================
# Spacing rules
# =============================================================================
# Spaces after keywords like 'if', 'for', 'while', 'switch'
csharp_space_after_keywords_in_control_flow_statements = true

# No spaces inside parentheses (e.g., if(condition) or MyMethod(arg))
csharp_space_between_parentheses = none
csharp_space_before_method_call_parentheses = true
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_before_method_declaration_parentheses = true
csharp_space_between_method_declaration_parameter_list_parentheses = false

# Spaces around binary operators
csharp_space_around_binary_operators = before_and_after

# No space after cast (int)x
csharp_space_after_cast = false

# Space after comma in method calls and declarations
csharp_space_after_comma = true

# =============================================================================
# Code style preferences
# =============================================================================
# Namespace declarations: block scoped (with braces)
csharp_style_namespace_declarations = block_scoped:warning

# Use var only when type is obvious (standard recommendation)
#csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Prefer collection expression syntax where possible
csharp_style_prefer_collection_expression = true:suggestion

# Prefer simple 'default' expression
csharp_prefer_simple_default_expression = true:suggestion

# Expression-bodied members – only for small members (default)
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_indexers = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion

# Prefer readonly fields when possible
dotnet_style_readonly_field = true:warning

# Use 'nameof' over string literals
dotnet_style_prefer_conditional_expression_over_assignment = false:suggestion

# Pattern matching preferences
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_style_deconstructed_variable_declaration = true:suggestion

# Prefer index/range operators
csharp_style_prefer_index_operator = true:suggestion
csharp_style_prefer_range_operator = true:suggestion

# For/foreach preference (standard: prefer foreach, but not enforced)
csharp_style_prefer_foreach = true:suggestion

# =============================================================================
# Naming conventions (standard .NET)
# =============================================================================
# Public members: PascalCase
dotnet_naming_rule.public_members_rule.severity = suggestion
dotnet_naming_rule.public_members_rule.symbols = public_symbols
dotnet_naming_rule.public_members_rule.style = pascal_case_style

dotnet_naming_symbols.public_symbols.applicable_kinds = class, struct, interface, enum, method, property, event, field
dotnet_naming_symbols.public_symbols.applicable_accessibilities = public, internal, protected, protected_internal

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# Private fields: _camelCase
dotnet_naming_rule.private_fields_rule.severity = suggestion
dotnet_naming_rule.private_fields_rule.symbols = private_fields
dotnet_naming_rule.private_fields_rule.style = underscore_camel_case_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case_style.capitalization = camel_case
dotnet_naming_style.underscore_camel_case_style.required_prefix = _

# Parameters and locals: camelCase
dotnet_naming_rule.locals_rule.severity = suggestion
dotnet_naming_rule.locals_rule.symbols = locals
dotnet_naming_rule.locals_rule.style = camel_case_style

dotnet_naming_symbols.locals.applicable_kinds = parameter, local

dotnet_naming_style.camel_case_style.capitalization = camel_case

# Constants: PascalCase (standard)
dotnet_naming_rule.constants_rule.severity = suggestion
dotnet_naming_rule.constants_rule.symbols = constants
dotnet_naming_rule.constants_rule.style = pascal_case_style

dotnet_naming_symbols.constants.applicable_kinds = field, local
dotnet_naming_symbols.constants.required_modifiers = const

# =============================================================================
# Code analysis severity – treat specific CA warnings as errors
# =============================================================================
dotnet_diagnostic.CA1816.severity = error   # Dispose methods should call SuppressFinalize
dotnet_diagnostic.CA2200.severity = error   # Rethrow to preserve stack details
dotnet_diagnostic.CA2213.severity = error   # Disposable fields should be disposed
dotnet_diagnostic.CA2215.severity = error   # Dispose methods should call base class dispose
dotnet_diagnostic.CA2218.severity = error   # Override GetHashCode on overriding Equals
dotnet_diagnostic.CA2219.severity = error   # Do not raise exceptions in finally clauses
dotnet_diagnostic.CA2224.severity = error   # Override Equals on overloading operator ==
dotnet_diagnostic.CA2227.severity = error   # Collection properties should be read only
dotnet_diagnostic.CA2241.severity = error   # Provide correct arguments to formatting methods
dotnet_diagnostic.CA1506.severity = error   # Avoid excessive class coupling
dotnet_diagnostic.CA1501.severity = error   # Avoid excessive inheritance
dotnet_diagnostic.CA1502.severity = error   # Avoid excessive complexity
dotnet_diagnostic.CA1307.severity = error   # Specify StringComparison for clarity
dotnet_diagnostic.CA1308.severity = error   # Normalize strings to uppercase
dotnet_diagnostic.CA1310.severity = error   # Specify StringComparison for correctness
dotnet_diagnostic.CA2119.severity = error   # Seal methods that satisfy private interfaces
dotnet_diagnostic.CA2013.severity = error   # Do not use ReferenceEquals with value types
dotnet_diagnostic.CA2012.severity = error   # Use ValueTasks correctly
dotnet_diagnostic.CA2011.severity = error   # Avoid infinite recursion in property setters
dotnet_diagnostic.CA1836.severity = error   # Prefer IsEmpty over Count when available
dotnet_diagnostic.CA1834.severity = error   # Use StringBuilder.Append(char) for single char strings
dotnet_diagnostic.CA1830.severity = error   # Prefer strongly-typed Append/Insert overloads on StringBuilder
dotnet_diagnostic.CA1835.severity = error   # Prefer memory-based overloads for Read/Write
dotnet_diagnostic.CA1829.severity = error   # Use Length/Count property instead of Enumerable.Count
dotnet_diagnostic.CA1827.severity = error   # Do not use Count/LongCount when Any can be used
dotnet_diagnostic.CA1825.severity = error   # Avoid zero-length array allocations
dotnet_diagnostic.CA1822.severity = error   # Mark members as static if they don't access instance data
dotnet_diagnostic.CA1812.severity = error   # Avoid uninstantiated internal classes

# =============================================================================
# Additional recommended analyzers (optional)
# =============================================================================
# Enforce XML documentation on public APIs (optional, but common in libraries)
dotnet_diagnostic.CS1591.severity = warning
