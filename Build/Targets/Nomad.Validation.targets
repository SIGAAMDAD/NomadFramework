<Project>
  <PropertyGroup>
    <NomadValidateAsModule Condition="'$(NomadValidateAsModule)' == ''">false</NomadValidateAsModule>
    <NomadAllowMissingPublicFolder Condition="'$(NomadAllowMissingPublicFolder)' == ''">false</NomadAllowMissingPublicFolder>
    <NomadAllowMissingPrivateFolder Condition="'$(NomadAllowMissingPrivateFolder)' == ''">false</NomadAllowMissingPrivateFolder>
  </PropertyGroup>

  <Target Name="ValidateNomadModuleLayout"
          BeforeTargets="BeforeBuild"
          Condition="'$(NomadValidateAsModule)' == 'true'">
    <Error Condition="'$(NomadAllowMissingPublicFolder)' != 'true' And !Exists('$(MSBuildProjectDirectory)/Public')"
           Text="$(MSBuildProjectName): module projects must contain a Public/ directory." />

    <Error Condition="'$(NomadAllowMissingPrivateFolder)' != 'true' And !Exists('$(MSBuildProjectDirectory)/Private')"
           Text="$(MSBuildProjectName): module projects must contain a Private/ directory." />

    <Error Condition="!Exists('$(MSBuildProjectDirectory)/README.md')"
           Text="$(MSBuildProjectName): module projects must contain a module-specific README.md." />

    <Error Condition="!Exists('$(MSBuildProjectDirectory)/ROADMAP.md')"
           Text="$(MSBuildProjectName): module projects must contain a module-specific ROADMAP.md." />
  </Target>

  <Target Name="PrintNomadProjectInfo"
          BeforeTargets="Build"
          Condition="'$(NomadPrintProjectInfo)' == 'true'">
    <Message Importance="high" Text="Nomad Project: $(MSBuildProjectName)" />
    <Message Importance="high" Text="  TargetFramework: $(TargetFramework)" />
    <Message Importance="high" Text="  TargetFrameworks: $(TargetFrameworks)" />
    <Message Importance="high" Text="  IsTestProject: $(IsTestProject)" />
    <Message Importance="high" Text="  IsPackable: $(IsPackable)" />
    <Message Importance="high" Text="  NomadEngine: $(NomadEngine)" />
    <Message Importance="high" Text="  NomadUseSourceGenerators: $(NomadUseSourceGenerators)" />
  </Target>
</Project>