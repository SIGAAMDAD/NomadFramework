<Project>
  <PropertyGroup Condition="'$(NomadEngineAdapter)' == 'true'">
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <EnforceCodeStyleInBuilds>true</EnforceCodeStyleInBuilds>
    <EnableUnsafeBinaryFormatterSerialization>false</EnableUnsafeBinaryFormatterSerialization>
    <BuildInParallel>true</BuildInParallel>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <TieredCompilation>true</TieredCompilation>
    <Deterministic>true</Deterministic>
    <UseSharedCompilation>true</UseSharedCompilation>
    <Optimize>true</Optimize>
    <SkipLocalsInit>true</SkipLocalsInit>

    <NoWarn>$(NoWarn);CA1812;CA1506</NoWarn>
  </PropertyGroup>

  <!-- Unity adapter defaults. -->
  <PropertyGroup Condition="'$(NomadEngine)' == 'Unity'">
    <TargetFrameworks Condition="'$(TargetFramework)' == '' And '$(TargetFrameworks)' == ''">netstandard2.1</TargetFrameworks>
    <LangVersion Condition="'$(LangVersion)' == ''">9.0</LangVersion>
    <DefineConstants>$(DefineConstants);NOMAD_ENGINE_UNITY;UNITY_COMPATIBLE</DefineConstants>

    <UnityVersion Condition="'$(UnityVersion)' == ''">6000.3.6f1</UnityVersion>
    <UnityInstallPath Condition="'$(UnityInstallPath)' == '' And '$(UNITY_HOME)' != ''">$(UNITY_HOME)</UnityInstallPath>

    <UnityInstallPath Condition="'$(UnityInstallPath)' == '' And Exists('C:\Program Files\Unity\Hub\Editor\$(UnityVersion)')">C:\Program Files\Unity\Hub\Editor\$(UnityVersion)</UnityInstallPath>
    <UnityInstallPath Condition="'$(UnityInstallPath)' == '' And Exists('/Applications/Unity/Hub/Editor/$(UnityVersion)')">/Applications/Unity/Hub/Editor/$(UnityVersion)</UnityInstallPath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(NomadEngine)' == 'Unity' And '$(OS)' == 'Windows_NT'">
    <UnityManagedPath>$(UnityInstallPath)/Editor/Data/Managed</UnityManagedPath>
    <UnityEnginePath>$(UnityManagedPath)/UnityEngine</UnityEnginePath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(NomadEngine)' == 'Unity' And '$(OS)' != 'Windows_NT'">
    <UnityManagedPath>$(UnityInstallPath)/Unity.app/Contents/Managed</UnityManagedPath>
    <UnityEnginePath>$(UnityManagedPath)/UnityEngine</UnityEnginePath>
  </PropertyGroup>

  <Target Name="ValidateUnityPaths"
          BeforeTargets="ResolveReferences"
          Condition="'$(NomadEngine)' == 'Unity' And '$(NomadValidateUnityPaths)' != 'false'">
    <Error Condition="'$(UnityInstallPath)' == ''"
           Text="Unity install path not found. Set UnityInstallPath or UNITY_HOME." />
    <Error Condition="!Exists('$(UnityEnginePath)/UnityEngine.CoreModule.dll')"
           Text="UnityEngine.CoreModule.dll not found under $(UnityEnginePath)." />
  </Target>

  <ItemGroup Condition="'$(NomadEngine)' == 'Unity' And '$(TargetFramework)' == 'netstandard2.1'">
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(UnityEnginePath)/UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.InputModule" Condition="Exists('$(UnityEnginePath)/UnityEngine.InputModule.dll')">
      <HintPath>$(UnityEnginePath)/UnityEngine.InputModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.AnimationModule" Condition="Exists('$(UnityEnginePath)/UnityEngine.AnimationModule.dll')">
      <HintPath>$(UnityEnginePath)/UnityEngine.AnimationModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Unity.InputSystem" Condition="Exists('$(MSBuildProjectDirectory)/Unity.InputSystem.dll')">
      <HintPath>$(MSBuildProjectDirectory)/Unity.InputSystem.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- Godot adapter defaults. -->
  <PropertyGroup Condition="'$(NomadEngine)' == 'Godot'">
    <TargetFrameworks Condition="'$(TargetFramework)' == '' And '$(TargetFrameworks)' == ''">net10.0</TargetFrameworks>
    <LangVersion Condition="'$(LangVersion)' == ''">14.0</LangVersion>
<!--    <PublishTrimmed Condition="'$(PublishTrimmed)' == 'true'">true</PublishTrimmed> -->
    <DefineConstants>$(DefineConstants);NOMAD_ENGINE_GODOT;NET10_0;USE_LATEST_FEATURES</DefineConstants>

    <GodotVersion Condition="'$(GodotVersion)' == ''">4.6.2</GodotVersion>
    <NomadUseDefaultGodotPackages Condition="'$(NomadUseDefaultGodotPackages)' == ''">true</NomadUseDefaultGodotPackages>
  </PropertyGroup>

  <!-- If you centralize Godot package refs here, remove duplicates from the Godot adapter csproj. -->
  <ItemGroup Condition="'$(NomadEngine)' == 'Godot' And '$(NomadUseDefaultGodotPackages)' == 'true'">
    <PackageReference Include="Godot.NET.Sdk" Version="$(GodotVersion)" />
    <PackageReference Include="Godot.SourceGenerators" Version="$(GodotVersion)" />
    <PackageReference Include="GodotSharp" Version="$(GodotVersion)" />
  </ItemGroup>
</Project>