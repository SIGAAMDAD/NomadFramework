<Project>
  <PropertyGroup>
    <EnableNETAnalyzers Condition="'$(EnableNETAnalyzers)' == ''">true</EnableNETAnalyzers>
    <AnalysisLevel Condition="'$(AnalysisLevel)' == ''">latest</AnalysisLevel>
    <EnforceCodeStyleInBuilds Condition="'$(EnforceCodeStyleInBuilds)' == ''">true</EnforceCodeStyleInBuilds>
  </PropertyGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);CA1501;CA2213</NoWarn>

    <WarningsAsErrors>
      $(WarningsAsErrors);
      CA1816;
      CA2200;
      CA2215;
      CA2218;
      CA2219;
      CA2224;
      CA2227;
      CA2241;
      CA1506;
      CA1307;
      CA1308;
      CA1310;
      CA2119;
      CA2013;
      CA2012;
      CA2011;
      CA1836;
      CA1834;
      CA1830;
      CA1835;
      CA1829;
      CA1827;
      CA1825;
      CA1822
    </WarningsAsErrors>
  </PropertyGroup>
</Project>