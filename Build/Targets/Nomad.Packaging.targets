<Project>
  <PropertyGroup Condition="'$(IsTestProject)' != 'true' And '$(IsTool)' != 'true' And '$(IsSampleProject)' != 'true'">
    <IsPackable Condition="'$(IsPackable)' == ''">true</IsPackable>

    <Authors Condition="'$(Authors)' == ''">Noah Van Til</Authors>
    <Company Condition="'$(Company)' == ''">GDR Software</Company>
    <Description Condition="'$(Description)' == ''">$(MSBuildProjectName) module for NomadFramework.</Description>

    <PackageLicenseExpression Condition="'$(PackageLicenseExpression)' == ''">MPL-2.0</PackageLicenseExpression>
    <PackageTags Condition="'$(PackageTags)' == ''">dotnet;library;framework;game-development;godot;unity</PackageTags>
    <PackageProjectUrl Condition="'$(PackageProjectUrl)' == ''">https://github.com/SIGAAMDAD/NomadFramework.git</PackageProjectUrl>

    <RepositoryUrl Condition="'$(RepositoryUrl)' == ''">https://github.com/SIGAAMDAD/NomadFramework.git</RepositoryUrl>
    <RepositoryType Condition="'$(RepositoryType)' == ''">git</RepositoryType>
    <RepositoryBranch Condition="'$(RepositoryBranch)' == '' And '$(GITHUB_REF_NAME)' != ''">$(GITHUB_REF_NAME)</RepositoryBranch>

    <PublishRepositoryUrl Condition="'$(PublishRepositoryUrl)' == ''">true</PublishRepositoryUrl>
    <GenerateDocumentationFile Condition="'$(GenerateDocumentationFile)' == ''">true</GenerateDocumentationFile>
    <IncludeSymbols Condition="'$(IncludeSymbols)' == ''">true</IncludeSymbols>
    <SymbolPackageFormat Condition="'$(SymbolPackageFormat)' == ''">snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources Condition="'$(EmbedUntrackedSources)' == ''">true</EmbedUntrackedSources>

    <PackageIcon Condition="'$(PackageIcon)' == ''">NomadFramework.png</PackageIcon>
    <PackageReadmeFile Condition="'$(PackageReadmeFile)' == ''">README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Do not generate packages during normal build unless explicitly requested. -->
  <PropertyGroup Condition="'$(GeneratePackages)' == 'true'">
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup Condition="'$(IsPackable)' == 'true'">
    <!-- Prefer module README when present. -->
    <None Include="$(MSBuildProjectDirectory)/README.md"
          Pack="true"
          PackagePath="\"
          Condition="Exists('$(MSBuildProjectDirectory)/README.md')" />

    <!-- Fall back to root README. -->
    <None Include="$(NomadRepoRoot)README.md"
          Pack="true"
          PackagePath="\"
          Condition="!Exists('$(MSBuildProjectDirectory)/README.md') And Exists('$(NomadRepoRoot)README.md')" />

    <None Include="$(NomadRepoRoot)NomadFramework.png"
          Pack="true"
          PackagePath="\"
          Condition="Exists('$(NomadRepoRoot)NomadFramework.png')" />
  </ItemGroup>

  <Target Name="ValidateNomadPackageMetadata"
          BeforeTargets="Pack"
          Condition="'$(IsPackable)' == 'true' And '$(NomadSkipPackageValidation)' != 'true'">
    <Error Condition="'$(PackageId)' == ''"
           Text="$(MSBuildProjectName): PackageId is required for packable Nomad modules." />
    <Error Condition="'$(Description)' == ''"
           Text="$(MSBuildProjectName): Description is required for packable Nomad modules." />
    <Error Condition="'$(PackageLicenseExpression)' == ''"
           Text="$(MSBuildProjectName): PackageLicenseExpression is required for packable Nomad modules." />
    <Error Condition="'$(PackageProjectUrl)' == ''"
           Text="$(MSBuildProjectName): PackageProjectUrl is required for packable Nomad modules." />
  </Target>
</Project>