#!/usr/bin/env bash 
 
echo "🚀 Running pre-commit tests..." 
 
if ! command -v dotnet > /dev/null 2>&1; then 
  echo "❌ .NET SDK not found" 
  exit 1 
fi 
 
if [ -d "Tests" ]; then 
  cd Source

  # ensure we don't forget anything
  git add *

  for dir in */ ; do
    echo "Formatting whitespace for $dir..."
    cd $dir
    if [[ -d "Public" ]]; then
      cd Public
      dotnet format whitespace --folder
      cd ..
    fi
    if [[ -d "Private" ]]; then
      cd Private
      dotnet format whitespace --folder
      cd ..
    fi
    cd ..
  done

  cd ..

  cd Tests
  dotnet test --configuration Release --verbosity minimal 
 
  if [ $? -ne 0 ]; then 
    echo "❌ Tests failed!" 
    echo "Use: git commit --no-verify to skip" 
    exit 1 
  else 
    echo "✅ Tests passed!" 
    exit 0 
  fi
else 
  echo "⚠️  No Tests/ directory found" 
  exit 0 
fi 
